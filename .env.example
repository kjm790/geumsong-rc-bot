# ───────────────────────────────────────────────────────────────
# 대구금송로타리클럽 'AI사무장봇' 설정 예시
# 이 파일을 복사해서 ".env" 로 저장한 뒤 값을 채우세요.
#   (PowerShell)  Copy-Item .env.example .env
# ───────────────────────────────────────────────────────────────

# [필수] BotFather 에게 받은 봇 토큰
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [필수] 클럽 단톡(그룹) chat ID — 보통 음수입니다. (예: -1001234567890)
#  → 봇을 그룹에 초대하고 그룹에서 /id 를 입력하면 확인됩니다.
GROUP_CHAT_ID=-1001234567890

# [선택] 임원 보고방 chat ID — 비워두면 임원방 보고를 생략합니다.
OFFICER_CHAT_ID=

# [필수] 관리자 텔레그램 user ID (쉼표로 여러 명). 봇에 /id 를 보내면 본인 user ID 확인.
ADMIN_IDS=11111111,22222222

# ── 정기 행사(EVENT) 설정 ─────────────────────────────────────
# WEEKDAY: 0=월 1=화 2=수 3=목 4=금 5=토 6=일
# NTH:     1=첫째 2=둘째 3=셋째 4=넷째 5=다섯째
# HOUR: 0~23 (24시간제), MINUTE: 0~59
# 행사는 EVENT1_, EVENT2_, EVENT3_ ... 처럼 번호를 늘려 추가할 수 있습니다.

# 행사1) 정기모임 — 첫째 화요일 19:30
EVENT1_NAME=정기모임
EVENT1_WEEKDAY=1
EVENT1_NTH=1
EVENT1_HOUR=19
EVENT1_MINUTE=30

# 행사2) 자유재활원 정기봉사 — 셋째 토요일 10:00
EVENT2_NAME=자유재활원 정기봉사
EVENT2_WEEKDAY=5
EVENT2_NTH=3
EVENT2_HOUR=10
EVENT2_MINUTE=0

# ── 발송 시각 / 리마인더 ───────────────────────────────────────
# 매일 점검(및 월말 출석조사 발송) 시각(시, 0~23). 기본 10시.
ANNOUNCE_HOUR=10
# 각 행사 며칠 전에 미응답자 리마인더를 보낼지. 기본 3일 전.
REMINDER_DAYS_BEFORE=3

# ── 동작 토글 (true/false) ─────────────────────────────────────
# 회원이 응답할 때 단톡에 칭찬 메시지를 올릴지
PRAISE_IN_GROUP=true
# 임원방에 현황 보고를 보낼지
REPORT_TO_OFFICERS=true

# [선택] SQLite 파일 경로
DB_PATH=samujang.db
